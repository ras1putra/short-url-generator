PORT=8080

DB_HOST=localhost
DB_PORT=5432
DB_NAME=urlshortener
DB_USER=postgres
DB_PASSWORD=secret
DB_MAX_CONNS=25

REDIS_ADDR=localhost:6379
REDIS_PASSWORD=

BASE_URL=http://localhost:8080

JWT_ACCESS_SECRET=your-access-secret
JWT_REFRESH_SECRET=your-refresh-secret

RATE_LIMIT_REDIRECT=60
RATE_LIMIT_CREATE=10


ALLOWED_ORIGINS=http://localhost:3000

# Bridge / anti-adblock
BRIDGE_HMAC_SECRET=your-bridge-hmac-secret

# Quality / anti-fraud
QUALITY_MIN_SCORE=0.50
MIN_SESSION_MS=18000

# Web3 / Ethereum
# Backend internal RPC (Docker network for dev, public RPC for prod)
NODE_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_KEY
CONTRACT_PAYMENT=0xYourPaymentGatewayAddress
CONTRACT_TOKEN=0xYourRewardTokenAddress
CONTRACT_FAUCET=0xYourFaucetAddress
CONTRACT_WITHDRAWER=0xYourWithdrawerAddress
FAUCET_SIGNER_KEY=0xYourFaucetSignerPrivateKey
TOKEN_SYMBOL=SURL
TOKEN_DECIMALS=18
OWNER_ADDRESS=0xYourOwnerAddress

# S3-compatible storage (Garage for dev, AWS S3 / other for prod)
S3_ENDPOINT=http://garage:3900
S3_REGION=us-east-1
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=short-url-ads
S3_PUBLIC_URL=http://short-url-ads.web.localhost:3902

# Chain config (for wallet deposit network switching)
# Dev defaults to Hardhat (chain 31337) with Blockscout at http://localhost:5100
# Override for other chains:
# CHAIN_ID=84532
# CHAIN_NAME=Base Sepolia
# CHAIN_RPC_URL=https://base-sepolia.g.alchemy.com/v2/YOUR_KEY
# EXPLORER_URL=https://sepolia.basescan.org
